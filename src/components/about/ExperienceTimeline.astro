---
import type { WorkExperience } from "@/types";

type Props = {
  experience: WorkExperience[];
};

const { experience } = Astro.props;
---

<div>
  <h2 class="mb-6 text-sm font-semibold tracking-[-0.01em] text-text-primary">
    Work experience
  </h2>

  <div class="flex flex-col">
    {
      experience.map((item) => (
        <article class="grid gap-2 border-b border-border py-6 min-[640px]:grid-cols-[140px_1fr] min-[640px]:gap-8">
          <time class="font-mono text-xs text-text-muted" datetime={item.dateRange}>
            {item.dateRange}
          </time>

          <div>
            <p class="mb-1 text-xs font-medium text-accent">{item.role}</p>
            <h3 class="mb-2 font-semibold text-text-primary">{item.company}</h3>

            <div class="text-sm leading-[1.55] text-text-muted">
              <p>{item.summary}</p>

              {item.highlights && item.highlights.length > 0 && (
                <ul class="mt-2 list-disc space-y-1 pl-5">
                  {item.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</div>
