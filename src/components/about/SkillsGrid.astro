---
import type { SkillCategory } from "@/types";

type Props = {
  categories: SkillCategory[];
};

const { categories } = Astro.props;
---

<div>
  <h2 class="mb-6 text-sm font-semibold tracking-[-0.01em] text-text-primary">
    Technical skills
  </h2>

  <div class="mb-12 grid gap-4 min-[600px]:grid-cols-2">
    {
      categories.map((category) => (
        <div class="rounded-lg border border-border p-4">
          <h3 class="mb-2 text-sm font-semibold text-text-primary">{category.title}</h3>
          <p class="text-[0.8125rem] leading-[1.5] text-text-muted">{category.skills}</p>
        </div>
      ))
    }
  </div>
</div>
