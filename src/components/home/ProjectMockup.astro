---
type Props = {
  browserUrl: string;
  imageSeed: string;
};

const { browserUrl, imageSeed } = Astro.props;
const imageUrl = `https://picsum.photos/seed/${imageSeed}/800/500`;
---

<div class="overflow-hidden rounded-lg border border-border">
  <div
    class="flex items-center gap-1.5 border-b border-border bg-[color-mix(in_oklch,var(--color-surface)_50%,var(--color-background))] px-3.5 py-2.5"
  >
    <span class="size-2 rounded-full bg-border" aria-hidden="true"></span>
    <span class="size-2 rounded-full bg-border" aria-hidden="true"></span>
    <span class="size-2 rounded-full bg-border" aria-hidden="true"></span>
    <span class="flex-1 text-center font-mono text-[0.625rem] text-text-muted">{browserUrl}</span>
  </div>
  <div class="relative aspect-[16/10] overflow-hidden bg-surface-secondary">
    <img
      src={imageUrl}
      alt=""
      width={800}
      height={500}
      loading="lazy"
      decoding="async"
      class="size-full object-cover"
    />
  </div>
</div>
