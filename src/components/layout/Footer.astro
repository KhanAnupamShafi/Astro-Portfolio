---
import Container from "@/components/layout/Container.astro";
import ButtonLink from "@/components/ui/ButtonLink.astro";
import SocialLinks from "@/components/ui/SocialLinks.astro";
import type { SocialLink } from "@/types";

type FooterActionLink = {
  href: string;
  label: string;
};

type Props = {
  name: string;
  socialLinks?: SocialLink[];
  actionLink?: FooterActionLink;
};

const { name, socialLinks = [], actionLink } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-border py-8">
  <Container class="flex flex-wrap items-center justify-between gap-4">
    <p class="text-sm text-text-muted">
      © {year} / <span class="text-text-primary">{name}</span>
    </p>

    {
      actionLink ? (
        <ButtonLink href={actionLink.href} variant="ghost">
          {actionLink.label}
        </ButtonLink>
      ) : (
        socialLinks.length > 0 && <SocialLinks links={socialLinks} />
      )
    }
  </Container>
</footer>
