---
import Container from "@/components/layout/Container.astro";
import ThemeToggle from "@/components/ui/ThemeToggle.astro";
import { isNavActive, navItems } from "@/lib/nav";
import FileText from "lucide-astro/FileText";
import Home from "lucide-astro/Home";
import LayoutGrid from "lucide-astro/LayoutGrid";
import User from "lucide-astro/User";

type Props = {
  timezone: string;
};

const { timezone } = Astro.props;
const pathname = Astro.url.pathname;

const iconMap = {
  home: Home,
  user: User,
  grid: LayoutGrid,
  file: FileText,
} as const;
---

<header
  class="sticky top-0 z-100 border-b border-border bg-background/85 backdrop-blur-md"
>
  <Container class="flex h-16 items-center justify-between gap-4">
    <p class="hidden font-mono text-xs tracking-wide text-text-muted whitespace-nowrap md:block">
      {timezone}
    </p>

    <nav
      aria-label="Main navigation"
      class="flex items-center gap-1 rounded-full border border-border bg-surface p-1"
    >
      {
        navItems.map((item) => {
          const Icon = iconMap[item.icon];
          const isActive = isNavActive(item.href, pathname);

          return (
            <a
              href={item.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm font-medium transition-colors duration-150 max-[480px]:p-2",
                isActive
                  ? "bg-surface-secondary text-text-primary"
                  : "text-text-muted hover:bg-surface-secondary hover:text-text-primary",
              ]}
            >
              <Icon class="size-4 shrink-0" aria-hidden="true" />
              <span class="max-[480px]:hidden">{item.label}</span>
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />
    </div>
  </Container>
</header>
