---
import ButtonLink from "@/components/ui/ButtonLink.astro";
import type { CaseStudySection, ProjectLinks } from "@/types";

type Props = {
  sections: CaseStudySection[];
  links: ProjectLinks;
};

const { sections, links } = Astro.props;
---

<div class="max-w-[65ch]">
  {
    sections.map((section) => (
      <div>
        <h2 class="mb-3 mt-8 text-lg font-semibold text-text-primary first:mt-0">
          {section.title}
        </h2>
        <p class="mb-4 text-[0.9375rem] leading-[1.65] text-text-muted">{section.content}</p>
      </div>
    ))
  }

  {
    (links.live || links.github) && (
      <div class="mt-12 flex flex-wrap gap-3">
        {links.live && (
          <ButtonLink href={links.live} variant="primary">
            View live demo
          </ButtonLink>
        )}
        {links.github && (
          <ButtonLink href={links.github} variant="secondary">
            Source on GitHub
          </ButtonLink>
        )}
      </div>
    )
  }
</div>
