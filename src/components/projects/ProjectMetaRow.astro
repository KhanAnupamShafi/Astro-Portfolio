---
import type { Project } from "@/types";

type Props = {
  project: Project;
};

const { project } = Astro.props;
const { role, timeline, techStack, links } = project;
---

<div
  class="mb-8 flex flex-wrap gap-6 border-b border-border pb-8 min-[640px]:gap-8"
>
  <div>
    <p class="mb-1 font-mono text-[0.6875rem] uppercase tracking-[0.08em] text-text-muted">
      Role
    </p>
    <p class="text-sm font-medium text-text-primary">{role}</p>
  </div>

  <div>
    <p class="mb-1 font-mono text-[0.6875rem] uppercase tracking-[0.08em] text-text-muted">
      Timeline
    </p>
    <p class="text-sm font-medium text-text-primary">{timeline}</p>
  </div>

  <div>
    <p class="mb-1 font-mono text-[0.6875rem] uppercase tracking-[0.08em] text-text-muted">
      Stack
    </p>
    <p class="text-sm font-medium text-text-primary">{techStack.join(", ")}</p>
  </div>

  {
    (links.github || links.live) && (
      <div>
        <p class="mb-1 font-mono text-[0.6875rem] uppercase tracking-[0.08em] text-text-muted">
          Links
        </p>
        <p class="text-sm font-medium">
          {links.github && (
            <a
              href={links.github}
              class="text-accent transition-colors duration-150 hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          )}
          {links.github && links.live && <span class="text-text-muted"> · </span>}
          {links.live && (
            <a
              href={links.live}
              class="text-accent transition-colors duration-150 hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Live demo
            </a>
          )}
        </p>
      </div>
    )
  }
</div>
