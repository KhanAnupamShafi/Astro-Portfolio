---
import type { ProjectMockupVariant } from "@/types";

type Props = {
  browserUrl: string;
  variant: ProjectMockupVariant;
  layout?: "card" | "hero";
};

const { browserUrl, variant, layout = "card" } = Astro.props;

const barClass = "h-2 rounded bg-border";
const cellClass =
  "h-12 rounded-md border border-border bg-[color-mix(in_oklch,var(--color-surface)_92%,var(--color-accent)_8%)]";
---

<div
  class:list={[
    "overflow-hidden bg-surface-secondary",
    layout === "card" ? "aspect-[16/10] border-b border-border" : "",
  ]}
>
  <div
    class="flex items-center gap-1.5 border-b border-border bg-[color-mix(in_oklch,var(--color-surface)_50%,var(--color-background))] px-3.5 py-2.5"
  >
    <span class="size-2 rounded-full bg-border" aria-hidden="true"></span>
    <span class="size-2 rounded-full bg-border" aria-hidden="true"></span>
    <span class="size-2 rounded-full bg-border" aria-hidden="true"></span>
    <span class="flex-1 text-center font-mono text-[0.625rem] text-text-muted">{browserUrl}</span>
  </div>

  {
    layout === "hero" ? (
      <div class="grid gap-4 p-8">
        <div class="grid grid-cols-2 gap-4 min-[640px]:grid-cols-4">
          <div class="h-16 rounded-md border border-border bg-[color-mix(in_oklch,var(--color-surface)_92%,var(--color-accent)_8%)]" />
          <div class="h-16 rounded-md border border-border bg-[color-mix(in_oklch,var(--color-surface)_92%,var(--color-accent)_8%)]" />
          <div class="h-16 rounded-md border border-border bg-[color-mix(in_oklch,var(--color-surface)_92%,var(--color-accent)_8%)]" />
          <div class="h-16 rounded-md border border-border bg-[color-mix(in_oklch,var(--color-surface)_92%,var(--color-accent)_8%)]" />
        </div>
        <div class="h-[200px] rounded-lg bg-border" />
      </div>
    ) : (
      <div class="grid gap-2 p-4">
        {variant === "grid-short" && (
          <>
            <div class:list={[barClass, "w-[40%]"]} />
            <div class="mt-2 grid grid-cols-3 gap-2">
              <div class={cellClass} />
              <div class={cellClass} />
              <div class={cellClass} />
            </div>
          </>
        )}
        {variant === "grid-full" && (
          <>
            <div class={barClass} />
            <div class="mt-2 grid grid-cols-3 gap-2">
              <div class={cellClass} />
              <div class={cellClass} />
              <div class={cellClass} />
            </div>
          </>
        )}
        {variant === "grid-medium" && (
          <>
            <div class:list={[barClass, "w-[65%]"]} />
            <div class="mt-2 grid grid-cols-3 gap-2">
              <div class={cellClass} />
              <div class={cellClass} />
              <div class={cellClass} />
            </div>
          </>
        )}
        {variant === "bars-short-full" && (
          <>
            <div class:list={[barClass, "w-[40%]"]} />
            <div class:list={[barClass, "mt-2"]} />
          </>
        )}
        {variant === "bars-medium-short" && (
          <>
            <div class:list={[barClass, "w-[65%]"]} />
            <div class:list={[barClass, "mt-2 w-[40%]"]} />
          </>
        )}
        {variant === "bars-full-short" && (
          <>
            <div class={barClass} />
            <div class:list={[barClass, "mt-2 w-[40%]"]} />
          </>
        )}
      </div>
    )
  }
</div>
