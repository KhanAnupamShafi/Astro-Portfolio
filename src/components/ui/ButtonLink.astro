---
type Props = {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  class?: string;
  download?: string | boolean;
  target?: string;
  rel?: string;
};

const { href, variant = "primary", class: className, download, target, rel } = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center gap-2 text-sm font-medium transition-colors duration-150";

const variantClasses = {
  primary:
    "rounded-lg border border-transparent bg-text-primary px-[1.125rem] py-2.5 text-background hover:opacity-90",
  secondary:
    "rounded-lg border border-border bg-transparent px-[1.125rem] py-2.5 text-text-primary hover:bg-surface-secondary",
  ghost: "px-3 py-2 text-text-muted hover:text-accent",
};
---

<a
  href={href}
  class:list={[baseClasses, variantClasses[variant], className]}
  download={download}
  target={target}
  rel={rel}
>
  <slot />
</a>
