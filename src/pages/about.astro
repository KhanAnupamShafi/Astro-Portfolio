---
import AboutIntro from "@/components/about/AboutIntro.astro";
import AboutProfile from "@/components/about/AboutProfile.astro";
import ExperienceTimeline from "@/components/about/ExperienceTimeline.astro";
import SkillsGrid from "@/components/about/SkillsGrid.astro";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Container from "@/components/layout/Container.astro";
import {
  buildSocialLinks,
  getAboutPhotoUrl,
  mapExperience,
  mapSkillCategories,
} from "@/lib/mappers";
import { ABOUT_QUERY, ALL_EXPERIENCE_QUERY } from "@/lib/queries";
import { sanityClient } from "@/lib/sanity";
import type { SanityAboutDocument, SanityExperienceDocument } from "@/types";

const about = await sanityClient.fetch<SanityAboutDocument | null>(ABOUT_QUERY);
const experienceDocs = await sanityClient.fetch<SanityExperienceDocument[]>(
  ALL_EXPERIENCE_QUERY,
);

if (!about) {
  throw new Error("About document not found in Sanity. Create the About singleton in Studio.");
}

const {
  name,
  title,
  bio,
  initials,
  location = "",
  availability = "",
} = about;

const socialLinks = buildSocialLinks(about);
const skillCategories = mapSkillCategories(about.skillCategories);
const experience = mapExperience(experienceDocs);
const photoUrl = getAboutPhotoUrl(about);
---

<BaseLayout
  title={`About — ${name}`}
  description={bio}
  footerActionLink={{ href: "/certificates", label: "Certificates →" }}
>
  <section class="py-[clamp(3rem,8vw,6rem)]">
    <Container>
      <div class="grid gap-12 min-[900px]:grid-cols-[280px_1fr] min-[900px]:items-start">
        <AboutProfile
          initials={initials}
          location={location}
          availability={availability}
          socialLinks={socialLinks}
          photoUrl={photoUrl}
        />

        <div>
          <AboutIntro name={name} title={title} bio={bio} />
          <SkillsGrid categories={skillCategories} />
          <ExperienceTimeline experience={experience} />
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
