---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Container from "@/components/layout/Container.astro";
import Tag from "@/components/ui/Tag.astro";
import { getAboutOgImageUrl, mapBlogPost } from "@/lib/mappers";
import { ABOUT_QUERY, POST_BY_SLUG_QUERY, POST_SLUGS_QUERY } from "@/lib/queries";
import { sanityClient } from "@/lib/sanity";
import { formatDate } from "@/lib/utils";
import type { GetStaticPaths } from "astro";
import type { SanityAboutDocument, SanityPostDocument } from "@/types";

export const getStaticPaths = (async () => {
  const slugs = await sanityClient.fetch<{ slug: string }[]>(POST_SLUGS_QUERY);

  return slugs.map(({ slug }) => ({
    params: { slug },
  }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
const postDoc = slug
  ? await sanityClient.fetch<SanityPostDocument | null>(POST_BY_SLUG_QUERY, { slug })
  : null;

if (!postDoc) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const about = await sanityClient.fetch<SanityAboutDocument | null>(ABOUT_QUERY);
const post = mapBlogPost(postDoc);
const ownerName = about?.name ?? "Portfolio";
const authorName = post.author?.trim() || ownerName;
const ogImageUrl = post.ogImageUrl ?? (about ? getAboutOgImageUrl(about) : undefined);
const formattedDate = formatDate(post.publishedAt);
---

<BaseLayout
  title={`${post.title} — ${ownerName}`}
  description={post.excerpt}
  image={ogImageUrl}
  imageAlt={post.title}
  type="article"
  siteName={ownerName}
  backLink={{ href: "/blog", label: "← Back to blog" }}
>
  <article class="py-[clamp(3rem,8vw,6rem)]">
    <Container>
      <div class="mx-auto w-full max-w-[680px]">
        <header class="mb-10">
          <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-text-muted">
            <time datetime={post.publishedAt}>{formattedDate}</time>
            <span aria-hidden="true">·</span>
            <span>{authorName}</span>
          </div>
          <h1
            class="mb-4 text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold leading-[1.15] tracking-[-0.025em] text-text-primary"
          >
            {post.title}
          </h1>
          <div class="flex flex-wrap gap-1.5">
            {post.tags.map((tag) => (
              <Tag label={tag} />
            ))}
          </div>
        </header>

        {
          post.coverImageUrl ? (
            <img
              src={post.coverImageUrl}
              alt=""
              width={1200}
              height={675}
              class="mb-10 w-full rounded-lg border border-border object-cover"
              loading="eager"
              decoding="async"
            />
          ) : null
        }

        <div class="prose" set:html={post.bodyHtml} />
      </div>
    </Container>
  </article>
</BaseLayout>
