---
import CertificateCard from "@/components/certificates/CertificateCard.astro";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Container from "@/components/layout/Container.astro";
import { mapCertificate } from "@/lib/mappers";
import { ABOUT_QUERY, ALL_CERTIFICATES_QUERY } from "@/lib/queries";
import { sanityClient } from "@/lib/sanity";
import type { SanityAboutDocument, SanityCertificateDocument } from "@/types";

const about = await sanityClient.fetch<SanityAboutDocument | null>(ABOUT_QUERY);
const certificateDocs = await sanityClient.fetch<SanityCertificateDocument[]>(
  ALL_CERTIFICATES_QUERY,
);
const certificates = certificateDocs.map(mapCertificate);

const ownerName = about?.name ?? "Portfolio";
const pageDescription =
  "Professional credentials and completed courses relevant to full-stack engineering.";
---

<BaseLayout title={`Certificates — ${ownerName}`} description={pageDescription}>
  <section class="py-[clamp(3rem,8vw,6rem)]">
    <Container>
      <h1
        class="mb-3 text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold leading-[1.15] tracking-[-0.025em] text-text-primary"
      >
        Certificates
      </h1>
      <p class="mb-12 max-w-[52ch] text-[clamp(1rem,1.5vw,1.125rem)] leading-[1.65] text-text-muted">
        {pageDescription}
      </p>

      {
        certificates.length > 0 ? (
          <div class="grid gap-6 min-[768px]:grid-cols-2">
            {certificates.map((certificate) => (
              <CertificateCard certificate={certificate} />
            ))}
          </div>
        ) : (
          <p class="text-center text-text-muted">No certificates yet.</p>
        )
      }
    </Container>
  </section>
</BaseLayout>
