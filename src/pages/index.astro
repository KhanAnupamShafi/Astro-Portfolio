---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import FeaturedProjects from "@/components/home/FeaturedProjects.astro";
import Hero from "@/components/home/Hero.astro";
import {
  buildSocialLinks,
  getAboutHeroPhotoUrl,
  getAboutOgImageUrl,
  getResumeDownload,
  mapFeaturedProject,
} from "@/lib/mappers";
import { ABOUT_QUERY, FEATURED_PROJECTS_QUERY } from "@/lib/queries";
import { sanityClient } from "@/lib/sanity";
import type { SanityAboutDocument, SanityProjectListItem } from "@/types";

const about = await sanityClient.fetch<SanityAboutDocument | null>(ABOUT_QUERY);
const featuredProjectDocs = await sanityClient.fetch<SanityProjectListItem[]>(
  FEATURED_PROJECTS_QUERY,
);

if (!about) {
  throw new Error("About document not found in Sanity. Create the About singleton in Studio.");
}

const { name, title, bio, availability, initials } = about;
const socialLinks = buildSocialLinks(about);
const featuredProjects = featuredProjectDocs.map(mapFeaturedProject);
const photoUrl = getAboutHeroPhotoUrl(about);
const ogImageUrl = getAboutOgImageUrl(about);
const resume = getResumeDownload(about);
---

<BaseLayout
  title={`${name} — ${title}`}
  description={bio}
  image={ogImageUrl}
  imageAlt={name}
  siteName={name}
  socialLinks={socialLinks}
  preloadImage={photoUrl}
>
  <Hero
    name={name}
    title={title}
    bio={bio}
    availability={availability ?? ""}
    initials={initials}
    photoUrl={photoUrl}
    socialLinks={socialLinks}
    resume={resume}
  />
  <FeaturedProjects projects={featuredProjects} />
</BaseLayout>
