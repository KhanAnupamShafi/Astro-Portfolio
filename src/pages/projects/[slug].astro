---
import ButtonLink from "@/components/ui/ButtonLink.astro";
import ProjectMetaRow from "@/components/projects/ProjectMetaRow.astro";
import ProjectWireframeMockup from "@/components/projects/ProjectWireframeMockup.astro";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Container from "@/components/layout/Container.astro";
import { getAboutOgImageUrl, mapProjectDetail } from "@/lib/mappers";
import { ABOUT_QUERY, PROJECT_BY_SLUG_QUERY, PROJECT_SLUGS_QUERY } from "@/lib/queries";
import { sanityClient } from "@/lib/sanity";
import type { GetStaticPaths } from "astro";
import type { SanityAboutDocument, SanityProjectDocument } from "@/types";

export const getStaticPaths = (async () => {
  const slugs = await sanityClient.fetch<{ slug: string }[]>(PROJECT_SLUGS_QUERY);

  return slugs.map(({ slug }) => ({
    params: { slug },
  }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
const projectDoc = slug
  ? await sanityClient.fetch<SanityProjectDocument | null>(PROJECT_BY_SLUG_QUERY, { slug })
  : null;

if (!projectDoc) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const project = mapProjectDetail(projectDoc);
const about = await sanityClient.fetch<SanityAboutDocument | null>(ABOUT_QUERY);
const ownerName = about?.name ?? "Portfolio";
const ogImageUrl = project.ogImageUrl ?? (about ? getAboutOgImageUrl(about) : undefined);
const { links } = project;
---

<BaseLayout
  title={`${project.title} — Case Study`}
  description={project.description}
  image={ogImageUrl}
  imageAlt={project.title}
  siteName={ownerName}
  backLink={{ href: "/projects", label: "← All projects" }}
  footerActionLink={{ href: "/projects", label: "More projects →" }}
>
  <article class="py-[clamp(3rem,8vw,6rem)]">
    <Container>
      <header class="mb-10">
        <p class="mb-4 font-mono text-[0.6875rem] uppercase tracking-[0.12em] text-text-muted">
          Case study
        </p>
        <h1
          class="mb-4 text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold leading-[1.15] tracking-[-0.025em] text-text-primary"
        >
          {project.title}
        </h1>
        <p class="max-w-[52ch] text-[clamp(1rem,1.5vw,1.125rem)] leading-[1.65] text-text-muted">
          {project.description}
        </p>
      </header>

      <div class="mb-10 overflow-hidden rounded-lg border border-border">
        {
          project.coverImageUrl ? (
            <img
              src={project.coverImageUrl}
              alt=""
              width={1200}
              height={750}
              loading="lazy"
              decoding="async"
              class="aspect-[16/10] w-full object-cover object-top"
            />
          ) : (
            <ProjectWireframeMockup
              browserUrl={project.slug}
              variant={project.mockupVariant ?? "grid-full"}
              layout="hero"
            />
          )
        }
      </div>

      <ProjectMetaRow project={project} />

      {
        project.bodyHtml ? (
          <div class="prose max-w-[65ch]" set:html={project.bodyHtml} />
        ) : null
      }

      {
        (links.live || links.github) && (
          <div class="mt-12 flex flex-wrap gap-3">
            {links.live && (
              <ButtonLink href={links.live} variant="primary">
                View live demo
              </ButtonLink>
            )}
            {links.github && (
              <ButtonLink href={links.github} variant="secondary">
                Source on GitHub
              </ButtonLink>
            )}
          </div>
        )
      }
    </Container>
  </article>
</BaseLayout>
