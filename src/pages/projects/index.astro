---
import ProjectCard from "@/components/projects/ProjectCard.astro";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Container from "@/components/layout/Container.astro";
import { projectsMock } from "@/lib/mock/projects";

const pageDescription =
  "Production systems, internal tools, and side projects — focused on full-stack delivery and clean architecture.";
---

<BaseLayout title="Selected projects — Khan Anupam Shafi" description={pageDescription}>
  <section class="py-[clamp(3rem,8vw,6rem)]">
    <Container>
      <h1
        class="mb-3 text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold leading-[1.15] tracking-[-0.025em] text-text-primary"
      >
        Selected projects
      </h1>
      <p class="mb-12 max-w-[52ch] text-[clamp(1rem,1.5vw,1.125rem)] leading-[1.65] text-text-muted">
        {pageDescription}
      </p>

      {
        projectsMock.length > 0 ? (
          <div class="grid gap-6 min-[768px]:grid-cols-2 min-[1024px]:grid-cols-3">
            {projectsMock.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        ) : (
          <p class="text-center text-text-muted">No projects yet.</p>
        )
      }
    </Container>
  </section>
</BaseLayout>
