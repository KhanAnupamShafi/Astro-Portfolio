---
import ProjectCard from "@/components/projects/ProjectCard.astro";
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Container from "@/components/layout/Container.astro";
import { getAboutOgImageUrl, mapProjectListItem } from "@/lib/mappers";
import { ABOUT_QUERY, ALL_PROJECTS_QUERY } from "@/lib/queries";
import { sanityClient } from "@/lib/sanity";
import type { SanityAboutDocument, SanityProjectListItem } from "@/types";

const about = await sanityClient.fetch<SanityAboutDocument | null>(ABOUT_QUERY);
const projectDocs = await sanityClient.fetch<SanityProjectListItem[]>(ALL_PROJECTS_QUERY);
const projects = projectDocs.map(mapProjectListItem);

const ownerName = about?.name ?? "Portfolio";
const pageDescription =
  "Production systems, internal tools, and side projects — focused on full-stack delivery and clean architecture.";
const ogImageUrl = about ? getAboutOgImageUrl(about) : undefined;
---

<BaseLayout
  title={`Selected projects — ${ownerName}`}
  description={pageDescription}
  image={ogImageUrl}
  imageAlt={ownerName}
  siteName={ownerName}
>
  <section class="py-[clamp(3rem,8vw,6rem)]">
    <Container>
      <h1
        class="mb-3 text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold leading-[1.15] tracking-[-0.025em] text-text-primary"
      >
        Selected projects
      </h1>
      <p class="mb-12 max-w-[52ch] text-[clamp(1rem,1.5vw,1.125rem)] leading-[1.65] text-text-muted">
        {pageDescription}
      </p>

      {
        projects.length > 0 ? (
          <div class="grid gap-6 min-[768px]:grid-cols-2 min-[1024px]:grid-cols-3">
            {projects.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        ) : (
          <p class="text-center text-text-muted">No projects yet.</p>
        )
      }
    </Container>
  </section>
</BaseLayout>
